# vector-retail environment configuration
# Copy to .env and fill in your values — never commit .env

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Secondary market data source
ALPHA_VANTAGE_API_KEY=your-av-key-here

# Optional: Deployment configuration
DEPLOYMENT_SLOT=blue          # blue | green | shadow
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# Optional: Production integrations (uncomment as needed)
# DATABASE_URL=postgresql://user:pass@localhost:5432/vector_retail
# REDIS_URL=redis://localhost:6379
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...
# HITL_WEBHOOK_URL=https://your-ticketing.example.com/webhook
# AWS_S3_AUDIT_BUCKET=your-worm-audit-bucket
