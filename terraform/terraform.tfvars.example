# ─────────────────────────────────────────────────────────────────────────────
# Example Terraform Variables
# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

project_name = "vector-retail"
environment  = "prod"
aws_region   = "us-east-1"

# Networking
vpc_cidr = "10.0.0.0/16"
az_count = 2

# Compute
container_cpu    = 1024    # 1 vCPU
container_memory = 2048    # 2 GB
desired_count    = 2
image_tag        = "v2.0.0"

# Secrets (provide via TF_VAR_anthropic_api_key env var or -var flag)
# anthropic_api_key = "sk-ant-..."
